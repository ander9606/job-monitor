# 1. Abre Telegram → busca @BotFather → /newbot → copia el token:
TELEGRAM_BOT_TOKEN=123456789:AABBCCDDEEFFaabbccddeeff-1234567890

# 2. Busca @userinfobot en Telegram → escríbele → copia tu Chat ID:
TELEGRAM_CHAT_ID=123456789

# Cada cuántas horas revisar (default: 2)
CHECK_INTERVAL_HOURS=2

# Tus habilidades para el comando /habilidades (separadas por coma)
MY_SKILLS=react,nodejs,full stack,react native,backend
